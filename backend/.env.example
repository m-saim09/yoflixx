PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/yoflix?retryWrites=true&w=majority

# JWT signing secret — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Frontend URLs used for CORS and cookies
CLIENT_URL=https://your-client-domain.vercel.app
ADMIN_URL=https://your-admin-domain.vercel.app

# Optional: comma-separated extra origins
# CORS_ORIGIN=https://another-frontend.example.com

# Local dev only — do NOT set in production
# DATABASE_PROVIDER=file
