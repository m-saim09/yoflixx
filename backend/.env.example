PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string (required in production)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/yoflix?retryWrites=true&w=majority

# Legacy alias — MONGODB_URI is preferred
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/yoflix

# JWT signing secret — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Vercel frontend URL (used for CORS in production)
CLIENT_URL=https://your-vercel-domain.vercel.app

# Optional: comma-separated extra origins (e.g. admin panel URL)
# CORS_ORIGIN=https://your-admin.vercel.app

# Local dev only — do NOT set in production
# DATABASE_PROVIDER=file
